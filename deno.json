{
  "nodeModulesDir": "auto",
  "imports": {
    "inngest": "npm:inngest@4.1.1",
    "inngest/edge": "npm:inngest@4.1.1/edge"
  },
  "tasks": {
    "dev": "deno run --watch --allow-env --allow-net --env-file=.env src/index.ts",
    "start": "deno run --allow-env --allow-net --env-file=.env src/index.ts",
    "ok": "deno fmt . && deno lint . && deno check \"src/**/*.ts\""
  }
}
